[gd_scene load_steps=2 format=3 uid="uid://poc_window"]

[ext_resource type="Script" path="res://poc/poc_window.gd" id="1_window"]

[node name="PocWindow" type="Node"]
script = ExtResource("1_window")

[node name="UI" type="CanvasLayer" parent="."]

[node name="VBox" type="VBoxContainer" parent="UI"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 20.0
offset_top = 20.0
offset_right = -20.0
offset_bottom = -20.0

[node name="Title" type="Label" parent="UI/VBox"]
text = "PoC 1: 항상 위 고정 + 픽셀 스케일링"

[node name="LabelStatus" type="Label" parent="UI/VBox"]
name = "LabelStatus"
text = "Always-on-Top: -"

[node name="LabelScale" type="Label" parent="UI/VBox"]
name = "LabelScale"
text = "창 크기: -"

[node name="BtnAlwaysOnTop" type="Button" parent="UI/VBox"]
name = "BtnAlwaysOnTop"
text = "Always-on-Top 켜기"

[node name="Hint" type="Label" parent="UI/VBox"]
text = "▶ 창을 자유롭게 늘려보세요\n▶ 버튼 클릭 후 다른 앱 위에 올려보세요\n▶ 픽셀이 깔끔하게 확대되는지 확인"
autowrap_mode = 3

[connection signal="pressed" from="UI/VBox/BtnAlwaysOnTop" to="." method="_on_btn_always_on_top_pressed"]
