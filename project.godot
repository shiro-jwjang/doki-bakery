; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but we're creating it programmatically for the initial setup.

config_version=5

[application]

config/name="DokinBakery"
config/description="두근두근 베이커리 - Doki-Doki Bakery"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.6", "Compatibility")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://scripts/autoload/game_manager.gd"

[display]

window/size/viewport_width=320
window/size/viewport_height=180
window/size/window_width_override=640
window/size/window_height_override=360
window/stretch/mode="viewport"

[rendering]

renderer/rendering_method="gl_compatibility"
